    .contact-link:hover { color: #333333; }
</style>

<script>
(function () {
    'use strict';

    /* ── Bio toggle ──────────────────────────────────────────────── */
    function toggleBio(btn) {
        var p   = btn.previousElementSibling;   /* the <p class="bio-text"> */
        var exp = p.classList.contains('bio-expanded');
        if (exp) {
            p.classList.remove('bio-expanded');
            btn.textContent = 'Read More';
        } else {
            p.classList.add('bio-expanded');
            btn.textContent = 'Show Less';
        }
    }
    window.toggleBio = toggleBio;   /* expose for onclick= attributes */

    /* ── Location filter ────────────────────────────────────────────
     * Each card has data-locations="state a|state b|..." (pipe-separated,
     * lowercase). Clicking a sidebar button shows only matching cards.
     */
    function applyFilter(btn) {
        var filter = btn.getAttribute('data-filter');

        /* Update active button state */
        document.querySelectorAll('.filter-btn').forEach(function (b) {
            b.classList.remove('active');
        });
        btn.classList.add('active');

        /* Show/hide cards */
        var cards   = document.querySelectorAll('.clinician-card');
        var visible = 0;

        cards.forEach(function (card) {
            if (filter === 'all') {
                card.style.display = '';
                visible++;
            } else {
                var locs = (card.getAttribute('data-locations') || '').split('|');
                var match = locs.some(function (l) { return l.trim() === filter; });
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            }
        });

        /* Show/hide no-results message */
        var noResults = document.getElementById('no-results');
        if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';

        /* Re-run Read More check since hidden cards may now be visible */
        syncReadMoreButtons();
    }
    window.applyFilter = applyFilter;

    /* ── Show Read More buttons where text is actually clipped ──────
     * Once a button is marked visible it stays visible — we never
     * hide it again. This prevents the flash caused by ResizeObserver
     * firing mid-layout when scrollHeight is temporarily unreliable
     * (e.g. during image loads or font swaps).
     */
    function syncReadMoreButtons() {
        document.querySelectorAll('.bio-text').forEach(function (p) {
            var btn = p.nextElementSibling;
            if (!btn || !btn.classList.contains('read-more-btn')) return;
            if (btn.classList.contains('visible')) return;
            if (p.scrollHeight > p.clientHeight + 4) {
                btn.classList.add('visible');
            }
        });
    }

    /* ── Lazy-load image fade-in ──────────────────────────────────
     * Adds .loaded class once the browser has decoded the image,
     * triggering the CSS opacity transition for a smooth appearance.
     */
    function initImageFade() {
        document.querySelectorAll('.card-img-wrap img').forEach(function (img) {
            if (img.complete && img.naturalWidth > 0) {
                img.classList.add('loaded');
            } else {
                img.addEventListener('load',  function () { img.classList.add('loaded'); });
                img.addEventListener('error', function () { img.classList.add('loaded'); }); /* still show slot */
            }
        });
    }

    /* ── Boot ─────────────────────────────────────────────────────── */
    document.addEventListener('DOMContentLoaded', function () {
        initImageFade();
        syncReadMoreButtons();

        /* ResizeObserver fires on initial layout AND any resize —
           covers web font swap, Kajabi sidebar open/close, etc.
           Wrapping in rAF prevents the "loop completed with undelivered
           notifications" console warning caused by callbacks that take
           longer than one animation frame to execute. */
        if (window.ResizeObserver) {
            var rafId;
            var ro = new ResizeObserver(function () {
                cancelAnimationFrame(rafId);
                rafId = requestAnimationFrame(syncReadMoreButtons);
            });
            ro.observe(document.getElementById('directory-grid'));
        } else {
            /* Fallback for older browsers */
            window.addEventListener('resize', syncReadMoreButtons);
        }
    });
})();
</script>

</body>
</html>
