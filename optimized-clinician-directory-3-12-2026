<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Mental Health Collective | Clinician Directory</title>

    <!-- Preconnect to speed up font and CDN fetches -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Display=swap prevents render blocking -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

    <!-- Tailwind via CDN — unavoidable in Kajabi custom code, but config is minimal -->
    <script>
        // Define config BEFORE Tailwind loads so it's picked up immediately
        window.tailwind = window.tailwind || {};
        tailwind = {
            config: {
                theme: {
                    extend: {
                        fontFamily: {
                            sans: ['Inter', 'sans-serif'],
                            serif: ['Playfair Display', 'serif'],
                        },
                        colors: {
                            sage:     '#6B7A6E',
                            sand:     '#C9AD8D',
                            bone:     '#FDFDFC',
                            charcoal: '#333333',
                        }
                    }
                }
            }
        };
    </script>
    <script src="https://cdn.tailwindcss.com" defer></script>

    <style>
        /* ─── Reset / base ─────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; }

        /* Kajabi navbar z-index safety */
        .navbar-collapse, .nav-menu, .kjb-navbar-collapse, .navbar { z-index: 9999 !important; }

        /* Sand color applied directly — bypasses Tailwind CDN timing */
        .location-label { color: #C9AD8D !important; }

        /* Prevent hero from stacking weirdly against Kajabi theme */
        #aimhc-directory { position: relative !important; top: auto !important; }

        /* ─── Card image wrapper ────────────────────────────────────── */
        /*
         * The sand accent bar lives on the WRAPPER, not the <img>.
         * This guarantees the bar is always visible regardless of
         * image aspect ratio, load state, or browser quirks.
         */
        .card-img-wrap {
            position: relative;
            width: 100%;
            height: 18rem;          /* 72 = 288px — matches h-72 */
            overflow: hidden;
            flex-shrink: 0;
        }
        .card-img-wrap::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 4px;
            background-color: #C9AD8D;  /* sand */
            z-index: 2;
        }
        .card-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            /* Smooth fade-in once loaded — avoids layout flash */
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        .card-img-wrap img.loaded { opacity: 1; }

        /* ─── Bio truncation ────────────────────────────────────────── */
        .bio-text {
            display: -webkit-box;
            -webkit-box-orient: vertical;
            -webkit-line-clamp: 5;
            overflow: hidden;
            transition: -webkit-line-clamp 0s;   /* clamp can't animate, keep instant */
        }
        .bio-expanded {
            -webkit-line-clamp: unset !important;
            overflow: visible;
        }

        /* ─── Card hover lift ───────────────────────────────────────── */
        .clinician-card {
            transition: box-shadow 0.25s ease, transform 0.25s ease;
            will-change: transform;
        }
        .clinician-card:hover {
            box-shadow: 0 20px 40px rgba(0,0,0,0.10);
            transform: translateY(-2px);
        }

        /* Hide Read More btn inline so there's no 200ms flash */
        .read-more-btn { display: none; }
        .read-more-btn.visible { display: inline-block; }

        /* ─── Sidebar layout ────────────────────────────────────────── */
        #directory-layout {
            display: flex;
            align-items: flex-start;
            gap: 2.5rem;
        }
        #filter-sidebar {
            width: 220px;
            flex-shrink: 0;
            position: sticky;
            top: 2rem;
        }
        #directory-grid-wrap { flex: 1; min-width: 0; }

        /* ─── Filter buttons ────────────────────────────────────────── */
        .filter-btn {
            display: block;
            width: 100%;
            text-align: left;
            padding: 0.45rem 0.75rem;
            border-radius: 0.375rem;
            font-size: 0.8rem;
            font-weight: 500;
            color: #555;
            background: transparent;
            border: none;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
            line-height: 1.4;
        }
        .filter-btn:hover { background: #f3f4f6; color: #333; }
        .filter-btn.active {
            background: #6B7A6E;
            color: #fff;
            font-weight: 600;
        }

        /* ─── No-results message ────────────────────────────────────── */
        #no-results {
            display: none;
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem 0;
            color: #9ca3af;
            font-size: 1rem;
        }

        /* ─── Mobile: sidebar becomes scrolling pill row ────────────── */
        @media (max-width: 767px) {
            #directory-layout { flex-direction: column; gap: 1.5rem; }
            #filter-sidebar {
                width: 100%;
                position: static;
                background: #fff;
                border: 1px solid #f3f4f6;
                border-radius: 0.75rem;
                padding: 1rem;
            }
            #filter-sidebar h3 { margin-bottom: 0.75rem; }
            #filter-list {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem;
            }
            .filter-btn {
                display: inline-block;
                width: auto;
                border: 1px solid #e5e7eb;
                padding: 0.3rem 0.75rem;
                border-radius: 999px;
            }
            .filter-btn.active { border-color: #6B7A6E; }
        }
    </style>
</head>

